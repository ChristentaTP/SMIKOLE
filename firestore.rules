rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Koleksi Profil Pengguna
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Koleksi Ponds dan sub-koleksi di bawahnya (realtime, control, fcr, ai)
    match /ponds/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Koleksi Notifikasi
    match /notifications/{notifId} {
      allow read, write: if request.auth != null;
    }

    // Koleksi Logbook
    match /logs/{logId} {
      allow read, write: if request.auth != null;
    }
  }
}